{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hermes RU Iola",
  "version": "0.17.6",
  "identifier": "ru.iola.hermes.tauri",
  "build": {
    "beforeDevCommand": "npm run dev:ui",
    "beforeBuildCommand": "npm run build:ui",
    "devUrl": "http://127.0.0.1:5176",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Hermes RU Iola",
        "width": 1280,
        "height": 840,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "transparent": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": false
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["hermes"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi", "appimage", "deb", "rpm"],
    "category": "DeveloperTool",
    "publisher": "Yakunin",
    "copyright": "Copyright (c) Yakunin",
    "shortDescription": "Легкое desktop-приложение Hermes RU Iola.",
    "longDescription": "Легкое desktop-приложение Hermes RU Iola на Rust и системном WebView.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  }
}
